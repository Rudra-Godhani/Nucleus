# Copy this file to `.env.local` and fill in the values from your Supabase project.
# Dashboard -> Project Settings -> API Keys
#
# .env.local is gitignored. Never commit real keys.

# Project URL, e.g. https://abcdefghijklm.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The *publishable* key (safe to expose to the browser).
# NOT the secret/service-role key — that key bypasses Row Level Security and
# must never be exposed to a client. Nucleus does not use it at all.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
